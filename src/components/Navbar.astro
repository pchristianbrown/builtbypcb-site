---
const { active = "" } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/90 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 md:px-6">
    
    <!-- Logo -->
    <a
      href="/"
      class="text-xs font-bold uppercase tracking-[0.25em] text-cyan-300 sm:text-sm"
    >
      BuiltByPCB
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-4 text-sm font-semibold md:flex">
      <a href="/" class={active === "home" ? "text-cyan-300" : "text-slate-300 transition hover:text-cyan-300"}>
        Home
      </a>

      <a href="/about" class={active === "about" ? "text-cyan-300" : "text-slate-300 transition hover:text-cyan-300"}>
        About
      </a>

      <a href="/case-studies" class={active === "case-studies" ? "text-cyan-300" : "text-slate-300 transition hover:text-cyan-300"}>
        Case Studies
      </a>

      <a href="/resume" class={active === "resume" ? "text-cyan-300" : "text-slate-300 transition hover:text-cyan-300"}>
        Resume
      </a>

      <a href="/projects" class={active === "projects" ? "text-cyan-300" : "text-slate-300 transition hover:text-cyan-300"}>
        Projects
      </a>

      <a
        href="/#contact"
        class="text-slate-300 transition hover:text-cyan-300"
      >
        Contact
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="menu-toggle"
      class="flex items-center rounded-lg border border-slate-700 p-2 text-slate-300 md:hidden"
      aria-label="Toggle Menu"
    >
      ☰
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-800 bg-slate-950 md:hidden"
  >
    <div class="flex flex-col px-4 py-4 text-sm font-semibold">
      <a href="/" class="py-2 text-slate-300 hover:text-cyan-300">
        Home
      </a>

      <a href="/about" class="py-2 text-slate-300 hover:text-cyan-300">
        About
      </a>

      <a href="/case-studies" class="py-2 text-slate-300 hover:text-cyan-300">
        Case Studies
      </a>

      <a href="/resume" class="py-2 text-slate-300 hover:text-cyan-300">
        Resume
      </a>

      <a href="/projects" class="py-2 text-slate-300 hover:text-cyan-300">
        Projects
      </a>

      <a href="/#contact" class="py-2 text-slate-300 hover:text-cyan-300">
        Contact
      </a>
    </div>
  </div>

  <!-- Mobile Toggle Script -->
  <script>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");

    toggle?.addEventListener("click", () => {
      menu?.classList.toggle("hidden");
    });
  </script>
</header>