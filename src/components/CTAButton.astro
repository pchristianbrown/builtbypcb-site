---
const {
  href = "#",
  variant = "primary",
  target = "",
  rel = "",
} = Astro.props;

const base =
  "inline-block rounded-xl px-5 py-3 font-semibold transition";

const styles = {
  primary: "bg-cyan-300 text-slate-950 hover:bg-cyan-200",
  secondary:
    "border border-cyan-300 text-cyan-300 hover:bg-cyan-300 hover:text-slate-950",
};
---

<a
  href={href}
  target={target}
  rel={rel}
  class={`${base} ${styles[variant] ?? styles.primary}`}
>
  <slot />
</a>