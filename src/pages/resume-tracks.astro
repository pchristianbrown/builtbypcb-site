---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
---

<BaseLayout
  title="Resume Tracks | BuiltByPCB"
  description="Operationally aligned resume tracks for security operations, operational resilience, governance, and cloud security."
  active="resume"
>
  <main id="top" class="px-4 py-10 text-slate-100 md:px-6 md:py-12">
    
    <section class="mx-auto max-w-6xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">
        Resume Tracks
      </p>

      <h1 class="max-w-5xl text-4xl font-bold tracking-tight md:text-5xl">
        Operationally aligned resume paths built around resilience, incident coordination, and governance trajectory.
      </h1>

      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        These resume tracks are intentionally segmented to align with distinct operational
        security pathways while maintaining a consistent focus on mission-critical systems,
        operational resilience, incident coordination, and governance-aligned execution.
      </p>
    </section>

    <!-- SECURITY OPS -->
    <section class="mx-auto mt-12 max-w-6xl">
      <div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 shadow-xl">
        
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">
              Track 01
            </p>

            <h2 class="mt-2 text-3xl font-bold">
              Security Operations & Incident Coordination
            </h2>
          </div>

          <span class="rounded-full border border-cyan-300 px-4 py-2 text-sm font-semibold text-cyan-300">
            Primary Track
          </span>
        </div>

        <p class="mt-6 max-w-4xl text-slate-300">
          Focused on mission-critical operations, operational resilience, incident coordination,
          escalation management, continuous monitoring, and restoration activities across
          globally distributed aviation surveillance environments.
        </p>

        <div class="mt-8 grid gap-6 md:grid-cols-2">
          
          <div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
            <h3 class="text-xl font-semibold text-cyan-300">
              Private Sector Resume
            </h3>

            <p class="mt-4 text-slate-300">
              Optimized for Security Operations, Incident Response, Operational Resilience,
              and Cyber Operations roles in enterprise and regulated environments.
            </p>

            <div class="mt-6">
              <CTAButton href="#">
                Download Resume
              </CTAButton>
            </div>
          </div>

          <div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
            <h3 class="text-xl font-semibold text-cyan-300">
              Federal Resume
            </h3>

            <p class="mt-4 text-slate-300">
              Structured for GS-12 through GS-14 operational cybersecurity, incident response,
              and operational continuity roles within federal and contractor environments.
            </p>

            <div class="mt-6">
              <CTAButton href="#" variant="secondary">
                Download Resume
              </CTAButton>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- GRC -->
    <section class="mx-auto mt-10 max-w-6xl">
      <div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 shadow-xl">

        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">
          Track 02
        </p>

        <h2 class="mt-2 text-3xl font-bold">
          Governance, Risk & Operational Resilience
        </h2>

        <p class="mt-6 max-w-4xl text-slate-300">
          Emphasizes operational governance, recovery validation, resilience activities,
          escalation governance, continuous monitoring, and operational documentation
          supporting high-availability infrastructure environments.
        </p>

        <div class="mt-8 grid gap-6 md:grid-cols-2">

          <div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
            <h3 class="text-xl font-semibold text-cyan-300">
              Private Sector Resume
            </h3>

            <p class="mt-4 text-slate-300">
              Tailored toward governance-aligned operational security, resilience,
              audit support, and operational risk coordination roles.
            </p>

            <div class="mt-6">
              <CTAButton href="#">
                Download Resume
              </CTAButton>
            </div>
          </div>

          <div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
            <h3 class="text-xl font-semibold text-cyan-300">
              Federal Resume
            </h3>

            <p class="mt-4 text-slate-300">
              Structured for operational governance, RMF-adjacent support,
              operational continuity, and resilience-focused federal roles.
            </p>

            <div class="mt-6">
              <CTAButton href="#" variant="secondary">
                Download Resume
              </CTAButton>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CLOUD -->
    <section class="mx-auto mt-10 max-w-6xl">
      <div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 shadow-xl">

        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">
          Track 03
        </p>

        <h2 class="mt-2 text-3xl font-bold">
          Cloud Security & ISSO Trajectory
        </h2>

        <p class="mt-6 max-w-4xl text-slate-300">
          Built around operational security, continuous monitoring, resilience,
          governance alignment, and cloud-security trajectory within high-availability
          operational environments.
        </p>

        <div class="mt-8 grid gap-6 md:grid-cols-2">

          <div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
            <h3 class="text-xl font-semibold text-cyan-300">
              Private Sector Resume
            </h3>

            <p class="mt-4 text-slate-300">
              Optimized for Cloud Security, operational security,
              and governance-oriented security engineering pathways.
            </p>

            <div class="mt-6">
              <CTAButton href="#">
                Download Resume
              </CTAButton>
            </div>
          </div>

          <div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
            <h3 class="text-xl font-semibold text-cyan-300">
              Federal Resume
            </h3>

            <p class="mt-4 text-slate-300">
              Structured for ISSO, cloud governance, operational security,
              and continuous monitoring responsibilities in federal environments.
            </p>

            <div class="mt-6">
              <CTAButton href="#" variant="secondary">
                Download Resume
              </CTAButton>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="mx-auto mt-12 max-w-6xl pb-6 text-center">
      <CTAButton href="#top" variant="secondary">
        Back to Top ↑
      </CTAButton>
    </div>

  </main>
</BaseLayout>