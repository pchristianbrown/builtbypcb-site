---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
import InfoCard from "../components/InfoCard.astro";

const caseStudies = [
  {
    title: "Incident Response Leadership",
    description:
      "Coordinated incident triage, escalation, documentation, and recovery actions in mission-critical aviation systems.",
  },
  {
    title: "Security Controls & Continuous Monitoring",
    description:
      "Supported NIST-aligned monitoring, evidence-quality documentation, control validation, and operational security reviews.",
  },
  {
    title: "Operational Resilience & Disaster Recovery",
    description:
      "Participated in readiness checks, DR tabletop exercises, and procedure improvements to strengthen service continuity.",
  },
];
---
<BaseLayout
<BaseLayout
  title="Resume | BuiltByPCB"
  description="Federal and private-sector resume tracks for PCB across security operations, GRC/risk, and cloud security."
  active="resume"
>
  <main id="top" class="px-4 py-10 text-slate-100 md:px-6 md:py-12">
  <section class="mx-auto max-w-4xl">
    <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300 sm:text-sm sm:tracking-[0.3em]">
      Resume
    </p>

    <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
      GS-13 Cybersecurity / Cloud Security Resume
    </h1>

    <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
      Federal-aligned resume focused on cybersecurity operations, incident response,
      NIST/RMF-aligned continuous monitoring, and mission-critical systems support.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/Paul_Christian_Brown_GS13_Resume.pdf"
        target="_blank"
        rel="noreferrer"
        class="inline-block rounded-xl bg-cyan-300 px-5 py-3 font-semibold text-slate-950 hover:bg-cyan-200"
      >
        Open Resume PDF
      </a>

      <a
        href="/case-studies"
        class="inline-block rounded-xl border border-cyan-300 px-5 py-3 font-semibold text-cyan-300 hover:bg-cyan-300 hover:text-slate-950"
      >
        View Case Studies
      </a>
    </div>

    <div class="mt-10 rounded-2xl border border-slate-800 bg-slate-900 p-6">
      <h2 class="text-2xl font-semibold text-cyan-300">Target Roles</h2>
      <ul class="mt-4 space-y-2 text-slate-300">
        <li>- IT Specialist / INFOSEC</li>
        <li>- ISSO / ISSE</li>
        <li>- Cloud Security Engineer</li>
        <li>- Cyber Incident Response Analyst</li>
        <li>- Security & Risk / GRC Analyst</li>
      </ul>
    </div>

    <div class="mt-10 rounded-2xl border border-slate-800 bg-slate-900 p-6">
      <h2 class="text-2xl font-semibold text-cyan-300">Resume Focus</h2>
      <p class="mt-4 text-slate-300">
        This resume emphasizes incident response leadership, continuous monitoring,
        vulnerability remediation coordination, audit-ready documentation, and security
        operations in high-availability environments.
      </p>
    </div>
  </section>
<section class="mx-auto mt-10 max-w-4xl">
  <div class="rounded-3xl border border-cyan-300/30 bg-slate-900 p-8">
    <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300 sm:text-sm sm:tracking-[0.3em]">
      Resume Tracks
    </p>

    <h2 class="text-3xl font-bold">Specialized Resume Tracks</h2>

    <p class="mt-4 text-slate-300">
      Role-specific resume tracks designed to align PCB’s operational background,
      CISSP credential, and security career goals with distinct hiring lanes.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <a
        href="/resume/security-operations"
        class="rounded-2xl border border-cyan-300 p-5 text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.2em]">Primary Lane</p>
        <h3 class="mt-3 font-semibold">Security Operations / IR</h3>
        <p class="mt-2 text-sm">
          Incident response, escalation, monitoring, and operational resilience.
        </p>
      </a>

      <a
        href="/resume/grc-risk"
        class="rounded-2xl border border-cyan-300 p-5 text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.2em]">Target Lane</p>
        <h3 class="mt-3 font-semibold">GRC / Risk</h3>
        <p class="mt-2 text-sm">
          Controls, evidence, remediation tracking, RMF, and risk communication.
        </p>
      </a>

      <a
        href="/resume/cloud-security"
        class="rounded-2xl border border-cyan-300 p-5 text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.2em]">Destination Lane</p>
        <h3 class="mt-3 font-semibold">Cloud Security / ISSO</h3>
        <p class="mt-2 text-sm">
          Shared responsibility, continuous monitoring, cloud governance, and ISSO-aligned support.
        </p>
      </a>
    </div>
  </div>
</section>

  <div class="mx-auto mt-12 max-w-6xl px-6 pb-4 text-center">
    <CTAButton href="#top" variant="secondary">
  Back to Top
</CTAButton>
  </div>
</main>
</BaseLayout>