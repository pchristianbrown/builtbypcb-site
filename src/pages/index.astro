---
const caseStudies = [
  {
    title: "Incident Response Leadership",
    description:
      "Coordinated incident triage, escalation, documentation, and recovery actions in mission-critical aviation systems.",
  },
  {
    title: "Security Controls & Continuous Monitoring",
    description:
      "Supported NIST-aligned monitoring, evidence-quality documentation, control validation, and operational security reviews.",
  },
  {
    title: "Operational Resilience & Disaster Recovery",
    description:
      "Participated in readiness checks, DR tabletop exercises, and procedure improvements to strengthen service continuity.",
  },
];
---

<main class="min-h-screen bg-slate-950 text-slate-100">
  <section class="mx-auto flex min-h-screen max-w-6xl flex-col justify-center px-6 py-20">
    <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">
      BuiltByPCB
    </p>

    <h1 class="max-w-4xl text-4xl font-bold tracking-tight md:text-6xl">
      CISSP-certified security and cloud operations professional.
    </h1>

    <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
      I help mission-critical environments improve incident response,
      continuous monitoring, resilience, and security operations through
      disciplined execution, clear documentation, and risk-informed decisions.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="#case-studies"
        class="rounded-xl bg-cyan-300 px-5 py-3 font-semibold text-slate-950 hover:bg-cyan-200"
      >
        View Case Studies
      </a>
      <a
        href="#contact"
        class="rounded-xl border border-slate-600 px-5 py-3 font-semibold text-slate-100 hover:border-cyan-300"
      >
        Contact PCB
      </a>
    </div>
  </section>

  <section class="border-y border-slate-800 bg-slate-900/60 px-6 py-16">
    <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-4">
      <div>
        <p class="text-3xl font-bold text-cyan-300">12+</p>
        <p class="text-slate-300">Years in mission-critical operations</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-cyan-300">CISSP</p>
        <p class="text-slate-300">Security leadership credential</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-cyan-300">Public Trust</p>
        <p class="text-slate-300">Federal stakeholder environment</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-cyan-300">24/7</p>
        <p class="text-slate-300">High-availability operational experience</p>
      </div>
    </div>
  </section>

  <section id="case-studies" class="mx-auto max-w-6xl px-6 py-20">
    <h2 class="text-3xl font-bold">Selected Case Studies</h2>
    <p class="mt-3 max-w-2xl text-slate-300">
      Practical examples of security operations, incident response, and resilience work.
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {caseStudies.map((study) => (
        <article class="rounded-2xl border border-slate-800 bg-slate-900 p-6 shadow-xl">
          <h3 class="text-xl font-semibold text-cyan-300">{study.title}</h3>
          <p class="mt-4 text-slate-300">{study.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-20">
    <h2 class="text-3xl font-bold">Core Strengths</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <div class="rounded-xl bg-slate-900 p-5">Incident Response & Escalation</div>
      <div class="rounded-xl bg-slate-900 p-5">NIST / RMF-Aligned Operations</div>
      <div class="rounded-xl bg-slate-900 p-5">Security Documentation & Audit Traceability</div>
      <div class="rounded-xl bg-slate-900 p-5">Cloud Security & Continuous Monitoring</div>
    </div>
  </section>

  <section id="contact" class="mx-auto max-w-6xl px-6 py-20">
    <div class="rounded-3xl border border-cyan-300/30 bg-slate-900 p-8">
      <h2 class="text-3xl font-bold">Open to security and cloud opportunities.</h2>
      <p class="mt-4 text-slate-300">
        Target roles: Security Engineer, Cloud Security, ISSO/ISSE, GRC/Risk, and Incident Response.
      </p>
      <a
        href="mailto:pchristianbrown@gmail.com"
        class="mt-6 inline-block rounded-xl bg-cyan-300 px-5 py-3 font-semibold text-slate-950 hover:bg-cyan-200"
      >
        Email PCB
      </a>
    </div>
  </section>
</main>