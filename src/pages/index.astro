---

import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
import InfoCard from "../components/InfoCard.astro";

const caseStudies = [
  {
    title: "Incident Response Leadership",
    description:
      "Coordinated incident triage, escalation, documentation, and recovery actions in mission-critical aviation systems.",
  },
  {
    title: "Security Controls & Continuous Monitoring",
    description:
      "Supported NIST-aligned monitoring, evidence-quality documentation, control validation, and operational security reviews.",
  },
  {
    title: "Operational Resilience & Disaster Recovery",
    description:
      "Participated in readiness checks, DR tabletop exercises, and procedure improvements to strengthen service continuity.",
  },
];
---
<BaseLayout
  title="BuiltByPCB | CISSP Security & Cloud Operations"
  description="BuiltByPCB is the professional portfolio of PCB, a CISSP-certified security and cloud operations professional."
  active="home"
>

  <!--main id="top" class="bg-mission-cyber text-slate-100" -->
    <!-- existing page content except Navbar/Footer -->

<main id="top" class="bg-mission-control text-slate-100">
  <section class="mx-auto flex max-w-6xl flex-col justify-center px-6 py-16 md:py-24">
    <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300 sm:text-sm sm:tracking-[0.3em]">
      BuiltByPCB
    </p>

    <h1 class="max-w-4xl text-4xl font-bold tracking-tight md:text-6xl">
  Mission-critical security operations and operational resilience for globally distributed aviation systems.
</h1>

<p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
  CISSP-certified security operations professional supporting high-availability aviation surveillance infrastructure across international stakeholder environments. Specialized in incident coordination, operational resilience, restoration sequencing, continuous monitoring, and governance-aligned operational execution.
</p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/resume"
        class="rounded-xl bg-cyan-300 px-5 py-3 font-semibold text-slate-950 hover:bg-cyan-200"
      >
        Download Resume
      </a>

      <a
        href="/case-studies"
        class="rounded-xl border border-cyan-300 px-5 py-3 font-semibold text-cyan-300 hover:bg-cyan-300 hover:text-slate-950"
      >
        View Case Studies
      </a>

      <a
        href="#contact"
        class="rounded-xl border border-slate-600 px-5 py-3 font-semibold text-slate-100 hover:border-cyan-300 hover:text-cyan-300"
      >
        Contact PCB
      </a>
    </div>
  </section>

  <section class="border-y border-slate-800 bg-slate-900/60 px-4 py-10 md:px-6 md:py-12 md:py-16">
    <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-4">
      <div>
        <p class="text-3xl font-bold text-cyan-300">12+</p>
        <p class="text-slate-300">Years in mission-critical operations</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-cyan-300">CISSP</p>
        <p class="text-slate-300">Security leadership credential</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-cyan-300">Public Trust</p>
        <p class="text-slate-300">Federal stakeholder environment</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-cyan-300">24/7</p>
        <p class="text-slate-300">High-availability operational experience</p>
      </div>
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-12">
  <h2 class="text-3xl font-bold">Operational Focus Areas</h2>

  <div class="mt-8 grid gap-6 md:grid-cols-3">
    <div class="rounded-2xl border border-slate-800 bg-slate-900 p-6">
      <h3 class="text-xl font-semibold text-cyan-300">
        Incident Coordination
      </h3>

      <p class="mt-4 text-slate-300">
        Coordinating operational response activities, escalation paths,
        stakeholder communications, and restoration sequencing during
        mission-critical incidents.
      </p>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-slate-900 p-6">
      <h3 class="text-xl font-semibold text-cyan-300">
        Governance & Risk Alignment
      </h3>

      <p class="mt-4 text-slate-300">
        Translating operational events into structured documentation,
        remediation tracking, audit traceability, and continuous
        monitoring practices aligned to security governance objectives.
      </p>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-slate-900 p-6">
      <h3 class="text-xl font-semibold text-cyan-300">
        Operational Resilience
      </h3>

      <p class="mt-4 text-slate-300">
        Supporting high-availability environments through process
        refinement, disaster recovery participation, operational
        consistency, and prevention-of-recurrence thinking.
      </p>
    </div>
  </div>
</section>

  <section class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-12 md:py-16">
    <h2 class="text-3xl font-bold">Selected Case Studies</h2>
    <p class="mt-3 max-w-2xl text-slate-300">
      Practical examples of security operations, incident response, and resilience work.
    </p>

    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {caseStudies.map((study) => (
        <article class="rounded-2xl border border-slate-800 bg-slate-900 p-6 shadow-xl">
          <h3 class="text-xl font-semibold text-cyan-300">{study.title}</h3>
          <p class="mt-4 text-slate-300">{study.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-12 md:py-16">
    <h2 class="text-3xl font-bold">Core Strengths</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <div class="rounded-xl bg-slate-900 p-5">Incident Coordination & Operational Leadership</div>
      <div class="rounded-xl bg-slate-900 p-5">Continuous Monitoring & Escalation Governance</div>
      <div class="rounded-xl bg-slate-900 p-5">Security Documentation & Audit Traceability</div>
      <div class="rounded-xl bg-slate-900 p-5">Operational Resilience & Disaster Recovery Support</div>
      <div class="rounded-xl bg-slate-900 p-5">Risk Communication & Cross Funtional Coordination</div>
      <div class="rounded-xl bg-slate-900 p-5">Mission-Critical Systems Operations</div>
    </div>
  </section>

  <section id="contact" class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-12 md:py-16">
    <div class="rounded-3xl border border-cyan-300/30 bg-slate-900 p-8">
      <h2 class="text-3xl font-bold">Open to security and cloud opportunities.</h2>
      <p class="mt-4 text-slate-300">
        Target roles: Security Engineer, Cloud Security, ISSO/ISSE, GRC/Risk, and Incident Response.
      </p>
      <a
        href="mailto:pchristianbrown@gmail.com"
        class="mt-6 inline-block rounded-xl bg-cyan-300 px-5 py-3 font-semibold text-slate-950 hover:bg-cyan-200"
      >
        Email PCB
      </a>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 pb-10 text-center">
    <a
      href="#top"
      class="inline-block rounded-xl border border-slate-600 px-5 py-3 text-sm font-semibold text-slate-300 hover:border-cyan-300 hover:text-cyan-300"
    >
      Back to Top
    </a>
  </div>
</main>
</BaseLayout>