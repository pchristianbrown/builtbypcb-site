---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
import InfoCard from "../components/InfoCard.astro";

const studies = [
  {
    title: "Incident Response Leadership in Mission-Critical Aviation System",
    situation:
      "Operating within a global aviation surveillance environment supporting federal and international stakeholders.",
    challenge:
      "Inconsistent incident workflows led to delays, unclear escalation paths, and weak documentation.",
    action:
      "Standardized incident response procedures, coordinated cross-functional teams, and improved escalation and reporting practices.",
    result:
      "Improved response consistency, faster resolution, and stronger audit traceability.",
  },
  {
    title: "Cloud Security Framework & Risk Reduction",
    situation:
      "Identified common cloud security gaps including IAM misconfiguration and lack of centralized logging.",
    challenge:
      "Limited visibility into user actions and weak control enforcement.",
    action:
      "Designed IAM structure, enabled logging, and established baseline monitoring workflows aligned to best practices.",
    result:
      "Improved visibility, reduced risk exposure, and strengthened audit posture.",
  },
  {
    title: "Vulnerability Management & Risk Governance",
    situation:
      "Vulnerabilities identified but lacked prioritization and ownership.",
    challenge:
      "Remediation tracking inconsistent and risk not clearly communicated.",
    action:
      "Established prioritization logic, coordinated remediation, and validated fixes.",
    result:
      "Improved accountability, reduced exposure, and stronger security posture.",
  },
];
---
<BaseLayout
  title="Case Studies | BuiltByPCB"
  description="Security operations, incident response, cloud security, and risk governance case studies from PCB."
  active="case-studies"
>

<main id="top" class="bg-slate-950 px-4 py-10 md:px-6 md:py-12 text-slate-100 md:py-16">
  <section class="mx-auto max-w-5xl">
    <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">
      Case Studies
    </p>

    <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
      Security operations proof, not just claims.
    </h1>

    <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
      Selected examples of incident response, continuous monitoring, cloud security,
      and risk governance work in mission-critical environments.
    </p>

    <div class="mt-10 space-y-6">
      {studies.map((study) => (
        <article class="rounded-2xl border border-slate-800 bg-slate-900 p-6 shadow-xl">
          <h2 class="text-2xl font-semibold text-cyan-300">{study.title}</h2>

          <div class="mt-6 space-y-4 text-slate-300">
            <p><strong class="text-slate-100">Situation:</strong> {study.situation}</p>
            <p><strong class="text-slate-100">Challenge:</strong> {study.challenge}</p>
            <p><strong class="text-slate-100">Action:</strong> {study.action}</p>
            <p><strong class="text-slate-100">Result:</strong> {study.result}</p>
          </div>
        </article>
      ))}
    </div>

    <section class="mx-auto mt-10 max-w-5xl">
  <div class="rounded-3xl border border-cyan-300/30 bg-slate-900 p-8">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">
      Detailed Tracks
    </p>

    <h2 class="text-3xl font-bold">Expanded Authority Case Studies</h2>

    <p class="mt-4 text-slate-300">
      Expanded narratives showing how PCB applies security operations, risk governance,
      and cloud security thinking in mission-critical environments.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <a
        href="/case-studies/incident-response"
        class="rounded-2xl border border-cyan-300 p-5 text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.2em]">Primary Proof</p>
        <h3 class="mt-3 font-semibold">Incident Response</h3>
        <p class="mt-2 text-sm">
          Operational response, escalation, communication, and recovery coordination.
        </p>
      </a>

      <a
        href="/case-studies/risk-governance"
        class="rounded-2xl border border-cyan-300 p-5 text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.2em]">Governance Proof</p>
        <h3 class="mt-3 font-semibold">Risk Governance</h3>
        <p class="mt-2 text-sm">
          Control evidence, remediation tracking, audit traceability, and risk communication.
        </p>
      </a>

      <a
        href="/case-studies/cloud-monitoring"
        class="rounded-2xl border border-cyan-300 p-5 text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.2em]">Cloud Proof</p>
        <h3 class="mt-3 font-semibold">Cloud Monitoring</h3>
        <p class="mt-2 text-sm">
          Shared responsibility, logging, evidence readiness, monitoring, and cloud control visibility.
        </p>
      </a>
    </div>
  </div>
</section>

    <div class="mt-10 rounded-3xl border border-cyan-300/30 bg-slate-900 p-8">
      <h2 class="text-2xl font-bold">Want the short version?</h2>
      <p class="mt-4 text-slate-300">
        These case studies map directly to PCB’s resume: incident response leadership,
        NIST/RMF-aligned operations, vulnerability governance, and security documentation.
      </p>

      <a
        href="/resume"
        class="mt-6 inline-block rounded-xl bg-cyan-300 px-5 py-3 font-semibold text-slate-950 hover:bg-cyan-200"
      >
        View Resume
      </a>
    </div>
  </section>

  <div class="mx-auto mt-12 max-w-6xl px-6 pb-4 text-center">
    <a
        href="#top"
        class="inline-block rounded-xl border border-cyan-300 px-5 py-3 font-semibold text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
>
      Back to Top
    </a>
  </div>
</main>
</BaseLayout>