---
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import CTAButton from "../../components/CTAButton.astro";
import InfoCard from "../../components/InfoCard.astro";
---
<Navbar active="security-operations" />

<main class="bg-slate-950 px-4 py-10 md:px-6 md:py-12 text-slate-100 md:py-16">
  <section class="mx-auto max-w-5xl">
    <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">
      Security Operations / Incident Response
    </p>

    <h1 class="max-w-4xl text-4xl font-bold tracking-tight md:text-6xl">
      Operationally mature security professional with mission-critical incident response experience.
    </h1>

    <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
      CISSP-certified cybersecurity professional with 12+ years supporting
      high-availability systems, incident escalation, operational resilience,
      and continuous monitoring in mission-critical environments.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/Paul_Christian_Brown_GS13_Resume.pdf"
        target="_blank"
        rel="noreferrer"
        class="inline-block rounded-xl bg-cyan-300 px-5 py-3 font-semibold text-slate-950 transition hover:bg-cyan-200"
      >
        Download Resume
      </a>

      <a
        href="/case-studies"
        class="inline-block rounded-xl border border-cyan-300 px-5 py-3 font-semibold text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
      >
        View Case Studies
      </a>
    </div>
  </section>

  <section class="mx-auto mt-12 max-w-5xl">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border border-slate-800 bg-slate-900 p-6">
        <h2 class="text-2xl font-semibold text-cyan-300">
          Core Competencies
        </h2>

        <ul class="mt-6 space-y-3 text-slate-300">
          <li>• Incident Response Coordination</li>
          <li>• Operational Escalation Management</li>
          <li>• Continuous Monitoring</li>
          <li>• SIEM / Alert Triage</li>
          <li>• Root Cause Analysis</li>
          <li>• Executive Incident Reporting</li>
          <li>• Vulnerability Coordination</li>
          <li>• Disaster Recovery Readiness</li>
        </ul>
      </div>

      <div class="rounded-2xl border border-slate-800 bg-slate-900 p-6">
        <h2 class="text-2xl font-semibold text-cyan-300">
          Operational Profile
        </h2>

        <div class="mt-6 space-y-4 text-slate-300">
          <p>
            12+ years supporting 24/7 operational environments.
          </p>

          <p>
            Experience coordinating high-priority incidents across engineering,
            operations, and stakeholder teams.
          </p>

          <p>
            Strong operational communication skills developed within
            mission-critical aviation surveillance environments.
          </p>

          <p>
            Active Public Trust and CISSP certification.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto mt-12 max-w-5xl">
    <div class="rounded-3xl border border-cyan-300/30 bg-slate-900 p-8">
      <h2 class="text-3xl font-bold">
        Representative Operational Experience
      </h2>

      <div class="mt-8 space-y-6 text-slate-300">
        <div>
          <h3 class="text-xl font-semibold text-cyan-300">
            Incident Response Leadership
          </h3>

          <p class="mt-2">
            Coordinated incident escalation, communication, and operational
            recovery activities supporting globally distributed aviation systems.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold text-cyan-300">
            Continuous Monitoring & Operational Visibility
          </h3>

          <p class="mt-2">
            Supported monitoring workflows, event triage, escalation handling,
            and operational reporting aligned with security and availability objectives.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold text-cyan-300">
            Resilience & Operational Stability
          </h3>

          <p class="mt-2">
            Participated in disaster recovery exercises, operational readiness
            reviews, and process improvements to strengthen service continuity.
          </p>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/case-studies"
          class="inline-block rounded-xl bg-cyan-300 px-5 py-3 font-semibold text-slate-950 transition hover:bg-cyan-200"
        >
          Explore Case Studies
        </a>

        <a
          href="/resume"
          class="inline-block rounded-xl border border-cyan-300 px-5 py-3 font-semibold text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
        >
          Back to Resume Hub
        </a>
      </div>
    </div>
  </section>

  <div class="mx-auto mt-12 max-w-6xl px-6 pb-4 text-center">
    <a
      href="#top"
      class="inline-block rounded-xl border border-cyan-300 px-5 py-3 font-semibold text-cyan-300 transition hover:bg-cyan-300 hover:text-slate-950"
    >
      Back to Top ↑
    </a>
  </div>
</main>
<Footer />